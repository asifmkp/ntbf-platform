# PostgreSQL connection string
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/foodstuffs?schema=public"

# Auth
JWT_SECRET="change-me-to-a-long-random-string"
JWT_EXPIRES_IN="1d"

# App
PORT=3000
NODE_ENV=development

# Business rules (from TRD)
CHEQUE_BOUNCE_CHARGE=250

# Zoho Books integration (ERP backbone). .com data center defaults shown.
# Create a Self Client in https://api-console.zoho.com to get these.
ZOHO_ORG_ID=928751913
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
ZOHO_REFRESH_TOKEN=
ZOHO_ACCOUNTS_HOST=https://accounts.zoho.com
ZOHO_API_HOST=https://www.zohoapis.com

# Zoho chart-of-account IDs (NTBFLLC confirmed defaults baked in; override if needed)
ZOHO_SALES_ACCOUNT=416943000000000388
ZOHO_COGS_ACCOUNT=416943000000034003
ZOHO_INVENTORY_ACCOUNT=416943000000034001
# Needed only for auto-posting cash expenses (get IDs from Zoho → Chart of Accounts):
ZOHO_EXPENSE_ACCOUNT=
ZOHO_CASH_ACCOUNT=

# Claude (Anthropic) — powers purchase-bill photo extraction + copilot
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# Security (set for any public deployment)
PUBLIC_API_TOKEN=          # if set, AI/Zoho/dashboard endpoints require header x-api-key: <token>
RATE_LIMIT_MAX=30          # max requests per IP per window on those endpoints
RATE_LIMIT_WINDOW_MS=60000
CORS_ORIGIN=               # comma-separated allowlist, e.g. https://app.yourdomain.com (empty = allow all, dev only)
