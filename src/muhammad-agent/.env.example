# ============================================================
# Muhammad Agent — environment configuration
# Copy this file to .env and fill in the real values.
# NEVER commit the real .env (it is gitignored).
# ============================================================

# --- Runtime ---
NODE_ENV=development
PORT=3005
# IANA timezone used for all @Cron daily schedules (7am, 8am, 5pm...).
# Staff are in the UAE, so Asia/Dubai is the default.
AGENT_TIMEZONE=Asia/Dubai
# Master kill switch. When false, the agent logs what it WOULD do but sends nothing.
AGENT_ENABLED=true

# --- Supabase (system of record for the agent) ---
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
# Use the SERVICE ROLE key (server-side only — full access, bypasses RLS). Keep secret.
SUPABASE_SERVICE_ROLE_KEY=

# --- 360dialog WhatsApp Business API ---
# Base URL is usually https://waba-v2.360dialog.io for Cloud API partners.
DIALOG360_BASE_URL=https://waba-v2.360dialog.io
DIALOG360_API_KEY=
# The WhatsApp phone-number / channel this agent sends from.
DIALOG360_FROM_NUMBER=
# Shared secret you set on the 360dialog inbound webhook, verified on POST.
WHATSAPP_WEBHOOK_SECRET=

# --- Owner (approvals go here; replies YES/NO come back from here) ---
# Owner WhatsApp in E.164 (no spaces, no +): +91 82814 36921 -> 918281436921
OWNER_WHATSAPP=918281436921

# --- Staff roster (E.164, no +). Also seeded into the DB; env is the fallback. ---
STAFF_TAHIR_WHATSAPP=971536460085
STAFF_MUSTHAFA_WHATSAPP=971526460084
STAFF_HARIS_WHATSAPP=971589800237

# --- Zoho Books ---
# Writes are OFF by default. The agent will draft/preview but not POST to Zoho
# until you flip this to true, so it can never touch live books untested.
ZOHO_WRITES_ENABLED=false
ZOHO_ORGANIZATION_ID=
ZOHO_ACCOUNTS_DOMAIN=https://accounts.zoho.com
ZOHO_API_DOMAIN=https://www.zohoapis.com
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
ZOHO_REFRESH_TOKEN=

# --- Business rules (order routing thresholds) ---
# Orders at/above this AED value always need owner approval.
APPROVAL_ORDER_VALUE_THRESHOLD_AED=1000
# Uncollected-cash reminder fires when a delivered order is older than this many hours.
CASH_COLLECTION_REMINDER_HOURS=24
# Quiet hours (agent-local time) — no non-urgent WhatsApp sent in this window.
QUIET_HOURS_START=22
QUIET_HOURS_END=6
# Failed-job retry: base delay (ms) and max attempts before escalating to owner.
RETRY_BASE_DELAY_MS=2000
RETRY_MAX_ATTEMPTS=5
